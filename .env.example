# Copy this file to .env and fill in your own values.
#   cp .env.example .env
# .env is gitignored and auto-loaded at startup — no need to `source` it.

# Which LLM backend to use: "openai" (default) or "claude".
MODEL_PROVIDER=openai
# Model id for the chosen provider.
#   openai example: gpt-5-nano
#   claude example: claude-sonnet-4-6
MODEL_NAME=gpt-5-nano

# API key for the chosen provider (only the matching one is required):
# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here
# Anthropic API key (only needed when MODEL_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Telegram bot token, issued by @BotFather (only needed for the Telegram bot)
TELEGRAM_BOT_TOKEN=123456789:your-telegram-bot-token-here
